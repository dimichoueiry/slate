{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/*.ts": { "runtime": "@vercel/node@5.1.10" },
    "api/research.ts": { "runtime": "@vercel/node@5.1.10", "maxDuration": 120 }
  }
}
